 +fn strip_compact_control_lines(text: &str) -> String {
 +    let control_markers = [
 +        "respond with text only",
 +        "do not call any tools",
 +        "do not use read",
 +        "tool calls will be rejected",
 +        "compacting control instructions",
 +    ];
 +    let mut result = String::with_capacity(text.len());
 +
 +    for line in text.lines() {
 +        let lower = line.to_ascii_lowercase();
 +        if control_markers.iter().any(|marker| lower.contains(marker)) {
 +            continue;
 +        }
 +        if !result.is_empty() {
 +            result.push('\n');
 +        }
 +        result.push_str(line);
 +    }
 +
 +    collapse_blank_lines(&result).trim().to_string()
 +}
