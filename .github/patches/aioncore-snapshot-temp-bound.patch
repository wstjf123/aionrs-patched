+#[derive(Debug, Default)]
+pub(super) struct SnapshotBaselinePaths {
+    pub paths: Vec<PathBuf>,
+    pub skipped: Vec<PathBuf>,
+}
+
+pub(super) fn collect_snapshot_baseline_paths(workspace: &Path) -> Result<SnapshotBaselinePaths, FileError> {
+    let mut result = SnapshotBaselinePaths::default();
+    let mut total_bytes = 0_u64;
+    let walker = WalkBuilder::new(workspace)
+        .hidden(false)
+        .git_ignore(true)
+        .git_global(true)
+        .git_exclude(true)
+        .filter_entry(|entry| {
+            let name = entry.file_name().to_string_lossy();
+            !matches!(
+                name.as_ref(),
+                "node_modules" | "dist" | "build" | "target" | ".venv" | "__pycache__" | ".next" | ".nuxt" | ".output"
+            )
+        })
+        .build();
+
+    for entry in walker {
+        let entry = entry.map_err(|e| FileError::Internal(format!("Failed to walk snapshot workspace: {}", e)))?;
+        let path = entry.path();
+        if path == workspace || !entry.file_type().is_some_and(|file_type| file_type.is_file()) {
+            continue;
+        }
+
+        let rel = path
+            .strip_prefix(workspace)
+            .map_err(|e| FileError::Internal(format!("Failed to relativize snapshot path {}: {}", path.display(), e)))?
+            .to_path_buf();
+        let metadata = entry
+            .metadata()
+            .map_err(|e| FileError::Internal(format!("Failed to stat snapshot file {}: {}", path.display(), e)))?;
+        let len = metadata.len();
+
+        if len > SNAPSHOT_MAX_FILE_BYTES || total_bytes.saturating_add(len) > SNAPSHOT_MAX_TOTAL_BYTES {
+            result.skipped.push(rel);
+            continue;
+        }
+
+        total_bytes += len;
+        result.paths.push(rel);
+    }
+
+    Ok(result)
+}
+
+fn append_snapshot_excludes(exclude_path: &Path, skipped: &[PathBuf]) -> Result<(), FileError> {
+    let mut content = std::fs::read_to_string(exclude_path)
+        .map_err(|e| FileError::Internal(format!("Failed to read snapshot exclude file: {}", e)))?;
+    content.push_str("\n# Skipped by AionUi snapshot size limits\n");
+    for path in skipped {
+        content.push_str(&git_exclude_path(path));
+        content.push('\n');
+    }
+    std::fs::write(exclude_path, content)
+        .map_err(|e| FileError::Internal(format!("Failed to append snapshot exclude rules: {}", e)))
+}
+
+fn git_exclude_path(path: &Path) -> String {
+    path.components()
+        .map(|component| component.as_os_str().to_string_lossy())
+        .collect::<Vec<_>>()
+        .join("/")
+}
